{
    "manifest_version": 3,
    "name": "Pathfind Chrome Extension",
    "version": "1.0.0",
    "description": "Save bookmarks to your self-hosted Pathfind instance.",
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "background": {
        "service_worker": "src/background.ts",
        "type": "module"
    }
}