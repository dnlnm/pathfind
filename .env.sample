# Database Configuration
# This is the path inside the Docker container
DATABASE_PATH=/app/data/pathfind.db

# Authentication Secret
# Generate a random string (e.g., using `openssl rand -base64 32`) for production use.
AUTH_SECRET=change-me-to-a-random-secret-in-production

# Initial Admin Credentials
ADMIN_EMAIL=admin@pathfind.local
ADMIN_PASSWORD=admin

# Application URLs
# Update these to match your domain or local IP in production
AUTH_URL=https://pathfind.nxim.dev
NEXT_PUBLIC_APP_URL=https://pathfind.nxim.dev

# Next Auth Trust Host (Required for Docker deployments where the host may differ)
AUTH_TRUST_HOST=true
